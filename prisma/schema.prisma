generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  id                  String   @id @default(uuid())
  title               String
  slug                String   @unique
  content             String   @db.Text
  amazonAffiliateLink String
  imageUrl            String
  brand               String
  modelNumber         String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  isDeal              Boolean  @default(false)
  discountPercentage  String?
  faqs                Json?
  ratingValue         Float    @default(4.5)
  ratingCount         Int      @default(89)
  category            String   @default("tactical")
  isVsArticle         Boolean  @default(false)
  tags                String[] @default([])
}

model products {
  asin          String   @id
  title         String?
  price         String?
  rating        String?
  review_count  String?
  image_url     String?
  product_url   String?
  is_published  Boolean  @default(false)
  post_link     String?
  created_at    DateTime @default(now())
}

model keyword_pool {
  id          String   @id @default(uuid())
  keyword     String   @unique
  brand       String?
  modelNumber String?
  status      String   @default("pending") // 'pending', 'processed', 'failed'
  createdAt   DateTime @default(now())
}

model sites {
  id           String   @id @default(uuid())
  name         String
  url          String?
  username     String?
  app_password String?
  n8n_webhook  String?
  keywords     String[] @default([])
  created_at   DateTime @default(now())
}

model bot_config {
  key         String   @id
  value       String?
  description String?
  updated_at  DateTime @default(now()) @updatedAt
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
